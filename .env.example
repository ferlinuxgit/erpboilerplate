# Required for local development, CI builds, migrations, and runtime.
# Use a non-secret CI/local database URL; do not commit real credentials.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erpboilerplate

# Required for build/runtime by Better Auth. Generate a strong random value per environment.
BETTER_AUTH_SECRET=replace-with-a-random-secret-minimum-32-chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Optional hardening/infrastructure.
ENABLE_CSRF=false
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional billing integration.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_DEFAULT_STRIPE_PRICE_ID=

# Optional transactional email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional S3/R2 object storage.
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
