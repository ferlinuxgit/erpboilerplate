# Sanitized test/E2E template. Copy to .env.test or inject these in CI.
# Never commit real credentials.
DATABASE_URL=postgresql://postgres:***@localhost:5432/erpboilerplate_test
BETTER_AUTH_SECRET=test-secret-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# E2E runner/server defaults.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
E2E_TEST_EMAIL=e2e-user@example.test
E2E_TEST_PASSWORD=replace-with-local-e2e-password

# Optional integrations kept empty/safe for test builds.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_DEFAULT_STRIPE_PRICE_ID=
RESEND_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
