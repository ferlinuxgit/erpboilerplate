# Coolify production example.
# Copy these keys into Coolify Environment Variables and replace every value marked with change-me.

# App runtime
NODE_ENV=production
PORT=3000
NEXT_TELEMETRY_DISABLED=1
LOG_LEVEL=info
WAIT_FOR_DATABASE=true
DATABASE_WAIT_TIMEOUT_SECONDS=60

# Run migrations automatically before starting the container.
# For a single Coolify instance this is convenient. For multiple replicas,
# run migrations as a separate deploy command and keep this false.
RUN_MIGRATIONS_ON_START=false

# Coolify build variables for the Dockerfile.
# Configure these as build variables too, not only runtime env vars.
APP_ORIGIN=https://change-me-your-domain.com
APP_PUBLIC_ORIGIN=https://change-me-your-domain.com
APP_PUBLIC_STRIPE_PRICE_ID=

# Database
# Neon example. Keep sslmode=require.
# Prefer the pooled Neon URL if you expect concurrent traffic.
DATABASE_URL=postgresql://change-me-user:change-me-password@change-me-host.neon.tech/change-me-db?sslmode=require

# Auth
# Generate strong secrets, for example:
# openssl rand -base64 48
JWT_SECRET=change-me-generate-a-long-random-secret
BETTER_AUTH_SECRET=change-me-generate-a-long-random-secret
BETTER_AUTH_URL=https://change-me-your-domain.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://change-me-your-domain.com

# Security
# Recommended in production because the app already sends x-csrf-token from client forms.
ENABLE_CSRF=true

# Stripe billing
# Leave empty if billing is not enabled yet.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_DEFAULT_STRIPE_PRICE_ID=

# Transactional email
# Leave empty if email sending is not enabled yet.
RESEND_API_KEY=
RESEND_FROM_EMAIL=ERP <noreply@change-me-your-domain.com>

# Object storage: AWS S3, Cloudflare R2 or compatible provider.
# Leave empty if uploads/storage are not enabled yet.
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# Rate limiting with Upstash Redis.
# Optional but recommended for public production deployments.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Build/release metadata.
# Optional. Coolify may provide its own commit SHA env; keep empty if unavailable.
GIT_SHA=
